# Copy this file to secrets.toml and fill in your values.
# On Streamlit Community Cloud, add these via the Secrets UI (app settings → Secrets).
# secrets.toml is git-ignored — never commit the real file.

ANTHROPIC_API_KEY = "sk-ant-..."

# Passphrase required to unlock Trade Wire article generation in the app.
# Share this with your league. Prevents public visitors from running up API costs.
LEAGUE_PASSWORD = "your-passphrase-here"
