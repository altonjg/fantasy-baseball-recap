# ============================================================
# IMPORTANT: This project lives inside iCloud Drive, so copy
# this file to ~/.config/fantasy_recap/.env  (NOT the project
# folder) so your credentials are never synced to Apple servers.
#
#   mkdir -p ~/.config/fantasy_recap
#   cp .env.example ~/.config/fantasy_recap/.env
#   chmod 600 ~/.config/fantasy_recap/.env
#
# Never commit .env to version control.
# ============================================================

# --- Yahoo Fantasy Sports ---
# Get these from https://developer.yahoo.com/apps/
# Create an app with:
#   - Redirect URI: oob
#   - API Permissions: Fantasy Sports → Read
YAHOO_CLIENT_ID=your_yahoo_client_id_here
YAHOO_CLIENT_SECRET=your_yahoo_client_secret_here

# Your league key: {game_key}.l.{league_id}
# game_key for MLB 2025 is typically 458 (check your league URL or run --print-data)
# league_id is the number in your Yahoo Fantasy league URL
# Example: 458.l.123456
YAHOO_LEAGUE_KEY=458.l.your_league_id_here

# --- Anthropic ---
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here

# --- Discord ---
# In your Discord server: Settings → Integrations → Webhooks → New Webhook
# Copy the webhook URL here
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here
